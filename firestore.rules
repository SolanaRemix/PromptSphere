rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: returns true when the caller is the designated admin.
    //
    // NOTE: The email check below matches the default NEXT_PUBLIC_ADMIN_EMAIL
    // value used by the application. For a production deployment, prefer
    // granting admin privileges via a Firebase custom claim set server-side
    // (e.g. `admin.auth().setCustomUserClaims(uid, { admin: true })`) and
    // replace this function body with:
    //   return request.auth.token.admin == true;
    // That approach does not require redeploying these rules when the admin
    // account changes.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "gxqstudio@gmail.com";
    }

    // Helper: true when the authenticated user can read the given prompt
    // (either owner, or the prompt is publicly visible).
    // Returns false if the prompt document doesn't exist.
    function canReadPrompt(promptId) {
      let p = get(/databases/$(database)/documents/prompts/$(promptId)).data;
      return request.auth != null
        && p != null
        && (p.userId == request.auth.uid || p.visibility == 'public');
    }

    // Users collection
    match /users/{uid} {
      // Any authenticated user may read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Admin may list all users
      allow list: if isAdmin();
    }

    // Prompts collection
    match /prompts/{promptId} {
      // Any authenticated user may read or create prompts
      allow read, create: if request.auth != null;
      // Only the owner may update or delete their own prompt
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Version history sub-collection
      match /versions/{versionId} {
        // Reads are restricted to users who can access the parent prompt
        // (owner, or prompt is public).
        allow read: if canReadPrompt(promptId);
        // Only the owner of the parent prompt may append version entries, and
        // the version document must reference the correct parent promptId.
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/prompts/$(promptId)).data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.promptId == promptId;
        // Versions are immutable once written
        allow update, delete: if false;
      }
    }

    // Roles collection – read-only for authenticated users, write requires admin
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Activity logs – write-only for authenticated users; read restricted to admin
    match /activityLogs/{logId} {
      allow create: if request.auth != null;
      allow read, list: if isAdmin();
    }

    // Real-time collaboration presence sessions.
    // Presence reads are scoped to users who can access the underlying prompt,
    // so private prompt collaborators are not visible to arbitrary signed-in users.
    match /collaborationSessions/{promptId} {
      match /presence/{presenceUserId} {
        // Only users who can read the prompt may see who is collaborating on it.
        allow read: if canReadPrompt(promptId);
        // Users may only write their own presence record, and only for prompts
        // they are allowed to access (prevents spamming arbitrary promptIds).
        allow write: if request.auth != null
          && request.auth.uid == presenceUserId
          && canReadPrompt(promptId);
      }
    }

    // Marketplace listings – public read, owner or admin write.
    match /marketplace/{listingId} {
      allow read, list: if true;

      // Owners may create a listing only for prompts they own.
      // Fields that represent system-managed aggregates (popularityScore,
      // salesCount, rating, ratingCount, ratingSum) must not be set on create
      // — they are initialised to 0 / not present until updated server-side.
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && get(/databases/$(database)/documents/prompts/$(request.resource.data.promptId)).data.userId == request.auth.uid
        && !request.resource.data.keys().hasAny(['popularityScore', 'salesCount', 'rating', 'ratingCount', 'ratingSum']);

      // Owners may update descriptive fields; only admin may modify aggregates.
      allow update: if request.auth != null
        && (
          (resource.data.ownerId == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['popularityScore', 'salesCount', 'rating', 'ratingCount', 'ratingSum', 'ownerId', 'promptId']))
          || isAdmin()
        );

      allow delete: if isAdmin();

      // Ratings sub-collection – any authenticated user may read/write their
      // own rating document.  Validated to contain only permitted fields and a
      // stars value within the valid 1–5 range.
      match /ratings/{userId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['stars', 'userId', 'createdAt'])
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5;
      }
    }

    // Payments – authenticated users can create a `pending` payment intent
    // for themselves; only a trusted backend (Admin SDK / Cloud Function)
    // should transition the status to `completed`.
    match /payments/{paymentId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        // Clients may only record a pending intent; server-side verification
        // is required before marking a payment completed.
        && request.resource.data.status == 'pending';
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      // Payments are immutable once written; only admin can update (e.g. refund).
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Affiliates – stable document ID == userId to prevent duplicates.
    // Authenticated users can create/update their own record; admin reads all.
    match /affiliates/{affiliateId} {
      allow create: if request.auth != null
        && affiliateId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null
        && (affiliateId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow delete: if isAdmin();

      // Referrals sub-collection – immutable audit trail; server-side writes
      // preferred in production (Admin SDK after payment verification).
      // Client writes allowed here to support the demo checkout flow.
      match /referrals/{paymentId} {
        allow read: if request.auth != null
          && (affiliateId == request.auth.uid || isAdmin());
        allow create: if request.auth != null;
        allow update, delete: if isAdmin();
      }
    }
  }
}

