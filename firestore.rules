rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: returns true when the caller is the designated admin.
    //
    // NOTE: The email check below matches the default NEXT_PUBLIC_ADMIN_EMAIL
    // value used by the application. For a production deployment, prefer
    // granting admin privileges via a Firebase custom claim set server-side
    // (e.g. `admin.auth().setCustomUserClaims(uid, { admin: true })`) and
    // replace this function body with:
    //   return request.auth.token.admin == true;
    // That approach does not require redeploying these rules when the admin
    // account changes.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "gxqstudio@gmail.com";
    }

    // Users collection
    match /users/{uid} {
      // Any authenticated user may read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Admin may list all users
      allow list: if isAdmin();
    }

    // Prompts collection
    match /prompts/{promptId} {
      // Any authenticated user may read or create prompts
      allow read, create: if request.auth != null;
      // Only the owner may update or delete their own prompt
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Version history sub-collection
      match /versions/{versionId} {
        // Any authenticated user may read versions of a prompt they can access
        allow read: if request.auth != null;
        // The userId written into the version document must match the caller.
        // This avoids a per-write read of the parent prompt document.
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        // Versions are immutable once written
        allow update, delete: if false;
      }
    }

    // Roles collection – read-only for authenticated users, write requires admin
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Activity logs – write-only for authenticated users; read restricted to admin
    match /activityLogs/{logId} {
      allow create: if request.auth != null;
      allow read, list: if isAdmin();
    }

    // Real-time collaboration presence sessions
    match /collaborationSessions/{promptId} {
      // Any authenticated user can read presence records (to see collaborators)
      allow read: if request.auth != null;

      match /presence/{userId} {
        // Users may only write their own presence record
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}

